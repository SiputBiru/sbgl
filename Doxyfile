PROJECT_NAME           = "SBgl"
PROJECT_NUMBER         = "0.1.0"
PROJECT_BRIEF          = "A graphics framework in C99"
OUTPUT_DIRECTORY       = build/docs
OPTIMIZE_OUTPUT_FOR_C  = YES
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
RECURSIVE              = YES
INPUT                  = docs/INDEX.md \
                         README.md \
                         CHANGELOG.md \
                         include \
                         src \
                         examples \
                         docs \
                         docs/getting_started/installation.md \
                         docs/getting_started/first_triangle.md \
                         docs/getting_started/window_setup.md \
                         docs/manual/windows_specific.md \
                         docs/manual/rendering_pipeline.md \
                         docs/manual/vulkan_backend.md \
                         docs/manual/memory_management.md \
                         docs/manual/platform_abstraction.md \
                         docs/manual/input_system.md \
                         docs/manual/camera_system.md \
                         docs/manual/math_library.md \
                         docs/manual/voxel_rendering.md \
                         docs/manual/telemetry.md \
                         docs/examples/index.md \
                         docs/COMPUTE.md \
                         docs/ROADMAP.md

EXCLUDE_PATTERNS       = */.git/* \
                         */build/* \
                         */build-*/* \
                         */.cache/* \
                         */docs/out/*
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = YES
PREDEFINED             = SBGL_ALIGN(n)=
GENERATE_LATEX         = NO
GENERATE_HTML          = YES
HAVE_DOT               = YES
WARN_IF_UNDOCUMENTED   = NO
MARKDOWN_SUPPORT       = YES
IMAGE_PATH             = docs/img
USE_MDFILE_AS_MAINPAGE = docs/INDEX.md

# --- Markdown ID Style for Header Links ---
MARKDOWN_ID_STYLE      = GITHUB

# --- Table of Contents ---
TOC_INCLUDE_HEADINGS   = 6

# --- File Patterns for Documentation ---
FILE_PATTERNS          = *.c \
                         *.h \
                         *.md \
                         *.markdown

# --- Modern HTML Settings ---
GENERATE_TREEVIEW      = YES
HTML_DYNAMIC_MENUS     = YES
USE_MATHJAX            = YES
MATHJAX_FORMAT         = HTML-CSS
MATHJAX_RELPATH        = https://cdn.jsdelivr.net/npm/mathjax@2

# --- Source Browsing ---
SOURCE_BROWSER         = YES
INLINE_SOURCES         = YES

