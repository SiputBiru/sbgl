PROJECT_NAME           = "SBgl"
PROJECT_NUMBER         = "0.1.0"
PROJECT_BRIEF          = "Bare-metal graphics framework in C99"
OUTPUT_DIRECTORY       = 
OPTIMIZE_OUTPUT_FOR_C  = YES
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
RECURSIVE              = YES
INPUT                  = include \
                         src \
                         examples \
                         docs \
                         README.md \
                         CHANGELOG.md \
                         docs/getting_started/first_triangle.md \
                         docs/getting_started/installation.md \
                         docs/getting_started/window_setup.md \
                         docs/manual/camera_system.md \
                         docs/manual/input_system.md \
                         docs/manual/math_library.md \
                         docs/manual/memory_management.md \
                         docs/manual/platform_abstraction.md \
                         docs/manual/rendering_pipeline.md \
                         docs/manual/voxel_rendering.md \
                         docs/manual/vulkan_backend.md

EXCLUDE_PATTERNS       = */.git/* \
                         */build/* \
                         */build-*/* \
                         */.cache/* \
                         */docs/out/*
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = YES
PREDEFINED             = SBGL_ALIGN(n)=
GENERATE_LATEX         = YES
GENERATE_HTML          = YES
HAVE_DOT               = NO
WARN_IF_UNDOCUMENTED   = NO
MARKDOWN_SUPPORT       = YES
IMAGE_PATH             = docs/img
USE_MDFILE_AS_MAINPAGE = README.md

# --- Source Browsing ---
SOURCE_BROWSER         = YES
INLINE_SOURCES         = YES

